generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum EmploymentStatus {
  ACTIVE
  LEFT
}

enum UserAddressType {
  HOME
  WORK
  OTHER
}

enum BookingStatus {
  DRAFT
  HOLD
  CONFIRMED
  PENDING_PAYMENT
  PAID
  ASSIGNMENT_PENDING
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FAILED
}

enum BookingAssignmentStatus {
  ASSIGNED
  ACCEPTED
  REJECTED
  STARTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  ZOHO
  MANUAL
  PLACEHOLDER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAUSED
}

enum BookingImageType {
  BEFORE_SERVICE
  AFTER_SERVICE
  ISSUE
  OTHER
}

enum BookingRatingType {
  CUSTOMER_TO_HERO
  HERO_TO_CUSTOMER
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum ServiceImageType {
  THUMBNAIL
  BANNER
  GALLERY
}

enum WorkerState {
  OFFLINE
  ONLINE
  AVAILABLE
  ASSIGNED
  ACCEPTED
  TRAVELLING
  IN_PROGRESS
  COMPLETED
}

enum AssignmentAttemptStatus {
  PENDING
  ACCEPTED
  REJECTED
  TIMEOUT
  CANCELLED
}

enum DeviceAppType {
  CUSTOMER
  HERO
  DASHBOARD
}

enum HeroVerificationStatus {
  DRAFT
  SUBMITTED
  PENDING_HUB_VERIFICATION
  VERIFIED
  REJECTED
  RESUBMISSION_REQUIRED
}

model mRoles {
  iMasterId             Int       @id @default(autoincrement())
  sCode                 String    @unique
  sName                 String    @unique
  precedence            Int       @unique
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users                 mUsers[]
  roleScreenPermissions mRoleScreenPermissions[]

  @@map("mroles")
}

model mUserTypes {
  iMasterId             Int       @id @default(autoincrement())
  sCode                 String    @unique
  sName                 String    @unique
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users mUsers[]

  @@map("musertypes")
}

model mUsers {
  iMasterId             Int              @id @default(autoincrement())
  username              String           @unique
  firstName             String?
  middleName            String?
  lastName              String?
  mobileNo              String?
  alternateNumber       String?
  email                 String?          @unique
  password              String
  iRoleMasterId         Int?
  iUserTypeMasterId     Int?
  employmentStatus      EmploymentStatus @default(ACTIVE)
  joinedAt              DateTime         @default(now())
  leftAt                DateTime?
  isActive              Boolean          @default(true)
  isDeleted             Boolean          @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  role                  mRoles?                  @relation(fields: [iRoleMasterId], references: [iMasterId])
  userType              mUserTypes?              @relation(fields: [iUserTypeMasterId], references: [iMasterId])
  addresses             mUserAddresses[]
  heroProfile           mHeroProfiles?
  heroOnboardingApplication tHeroOnboardingApplications? @relation("HeroOnboardingApplicant")
  customerProfile       mCustomerProfiles?
  employeeProfile       mEmployeeProfiles?
  heroServiceMappings   mHeroServiceMappings[]   @relation("HeroServiceMappings")
  heroServiceAreas      mHeroServiceAreas[]      @relation("HeroServiceAreas")
  heroLiveLocation      mHeroLiveLocations?
  customerBookings      tBookings[]              @relation("CustomerBookings")
  bookingAssignments    tBookingAssignments[]    @relation("HeroAssignments")
  uploadedImages        tBookingImages[]         @relation("BookingImageUploader")
  ratingsGiven          tBookingRatings[]        @relation("RatingsGiven")
  ratingsReceived       tBookingRatings[]        @relation("RatingsReceived")
  payments              tPayments[]              @relation("PaymentPayer")
  customerSubscriptions mSubscriptions[]         @relation("CustomerSubscriptions")
  authSessions          AuthSession[]
  userScreenPermissions mUserScreenPermissions[]
  deviceTokens          mDeviceTokens[]
  bookingStatusChanges  tBookingStatusHistory[]  @relation("BookingStatusChangedBy")
  assignmentAttempts    tAssignmentAttempts[]    @relation("AssignmentAttemptHero")
  idempotencyKeys       tIdempotencyKeys[]       @relation("IdempotencyCreatedBy")
  verifiedHeroOnboardingApplications tHeroOnboardingApplications[] @relation("HeroOnboardingVerifiedBy")

  @@map("musers")
}

model mUserAddresses {
  iMasterId             Int             @id @default(autoincrement())
  iUserMasterId         Int
  addressType           UserAddressType @default(HOME)
  addressLine1          String
  addressLine2          String?
  landmark              String?
  city                  String?
  state                 String?
  pincode               String?
  latitude              Decimal?        @db.Decimal(10, 7)
  longitude             Decimal?        @db.Decimal(10, 7)
  isDefault             Boolean         @default(false)
  isActive              Boolean         @default(true)
  isDeleted             Boolean         @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user     mUsers      @relation(fields: [iUserMasterId], references: [iMasterId], onDelete: Cascade)
  bookings tBookings[]

  @@index([iUserMasterId])
  @@map("museraddresses")
}

model mHeroProfiles {
  iMasterId             Int         @id @default(autoincrement())
  iUserMasterId         Int         @unique
  heroCode              String?     @unique
  governmentIdNumber    String?
  skillSummary          String?
  averageRating         Decimal     @default(0.00) @db.Decimal(3, 2)
  totalRatings          Int         @default(0)
  isActive              Boolean     @default(true)
  isAvailable           Boolean     @default(true)
  workerState           WorkerState @default(OFFLINE)
  isVerified            Boolean     @default(false)
  verificationStatus    HeroVerificationStatus @default(DRAFT)
  isDeleted             Boolean     @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user mUsers @relation(fields: [iUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@map("mheroprofiles")
}

model mCustomerProfiles {
  iMasterId             Int       @id @default(autoincrement())
  iUserMasterId         Int       @unique
  customerCode          String?   @unique
  averageRating         Decimal   @default(0.00) @db.Decimal(3, 2)
  totalRatings          Int       @default(0)
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user mUsers @relation(fields: [iUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@map("mcustomerprofiles")
}

model mEmployeeProfiles {
  iMasterId             Int       @id @default(autoincrement())
  iUserMasterId         Int       @unique
  employeeCode          String?   @unique
  designation           String?
  department            String?
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user mUsers @relation(fields: [iUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@map("memployeeprofiles")
}

model mServiceCategories {
  iMasterId             Int       @id @default(autoincrement())
  sCode                 String    @unique
  sName                 String    @unique
  description           String?   @db.Text
  displayOrder          Int       @default(0)
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  services mServices[]

  @@map("mservicecategories")
}

model mServiceTypes {
  iMasterId             Int       @id @default(autoincrement())
  sCode                 String    @unique
  sName                 String    @unique
  description           String?   @db.Text
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  services mServices[]

  @@map("mservicetypes")
}

model mServices {
  iMasterId                Int       @id @default(autoincrement())
  iServiceCategoryMasterId Int
  iServiceTypeMasterId     Int
  sCode                    String    @unique
  sName                    String    @unique
  description              String?   @db.Text
  shortDescription         String?
  basePrice                Decimal   @db.Decimal(10, 2)
  salePrice                Decimal?  @db.Decimal(10, 2)
  taxPercentage            Decimal?  @db.Decimal(5, 2)
  estimatedDurationMinutes Int
  minQuantity              Int       @default(1)
  maxQuantity              Int?
  isSlotRequired           Boolean   @default(true)
  isSubscriptionEligible   Boolean   @default(false)
  requiresBeforeImage      Boolean   @default(false)
  requiresAfterImage       Boolean   @default(false)
  isActive                 Boolean   @default(true)
  isDeleted                Boolean   @default(false)
  deletedAt                DateTime?
  deletedByUserMasterId    Int?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  category       mServiceCategories       @relation(fields: [iServiceCategoryMasterId], references: [iMasterId])
  serviceType    mServiceTypes            @relation(fields: [iServiceTypeMasterId], references: [iMasterId])
  slots          mServiceSlots[]
  images         mServiceImages[]
  couponMappings mCouponServiceMappings[]
  heroMappings   mHeroServiceMappings[]
  bookings       tBookings[]

  @@index([iServiceCategoryMasterId])
  @@index([iServiceTypeMasterId])
  @@map("mservices")
}

model mServiceSlots {
  iMasterId             Int       @id @default(autoincrement())
  iServiceMasterId      Int?
  slotName              String
  startTime             DateTime  @db.Time(0)
  endTime               DateTime  @db.Time(0)
  maxBookings           Int       @default(1)
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  service  mServices?  @relation(fields: [iServiceMasterId], references: [iMasterId], onDelete: Cascade)
  bookings tBookings[]

  @@index([iServiceMasterId])
  @@map("mserviceslots")
}

model mServiceImages {
  iMasterId             Int              @id @default(autoincrement())
  iServiceMasterId      Int
  imageUrl              String
  imageType             ServiceImageType @default(GALLERY)
  displayOrder          Int              @default(0)
  isActive              Boolean          @default(true)
  isDeleted             Boolean          @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  service mServices @relation(fields: [iServiceMasterId], references: [iMasterId], onDelete: Cascade)

  @@index([iServiceMasterId])
  @@map("mserviceimages")
}

model mSubscriptionTypes {
  iMasterId             Int       @id @default(autoincrement())
  sCode                 String    @unique
  sName                 String    @unique
  description           String?   @db.Text
  durationDays          Int
  discountPercent       Decimal?  @db.Decimal(5, 2)
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  subscriptions mSubscriptions[]

  @@map("msubscriptiontypes")
}

model mSubscriptions {
  iMasterId                 Int                @id @default(autoincrement())
  iSubscriptionTypeMasterId Int
  iCustomerUserMasterId     Int
  startAt                   DateTime
  endAt                     DateTime
  status                    SubscriptionStatus @default(ACTIVE)
  isActive                  Boolean            @default(true)
  isDeleted                 Boolean            @default(false)
  deletedAt                 DateTime?
  deletedByUserMasterId     Int?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  subscriptionType mSubscriptionTypes @relation(fields: [iSubscriptionTypeMasterId], references: [iMasterId])
  customer         mUsers             @relation("CustomerSubscriptions", fields: [iCustomerUserMasterId], references: [iMasterId])
  bookings         tBookings[]

  @@index([iSubscriptionTypeMasterId])
  @@index([iCustomerUserMasterId])
  @@map("msubscriptions")
}

model mCoupons {
  iMasterId             Int          @id @default(autoincrement())
  sCode                 String       @unique
  sName                 String
  description           String?      @db.Text
  discountType          DiscountType
  discountValue         Decimal      @db.Decimal(10, 2)
  maxDiscountAmount     Decimal?     @db.Decimal(10, 2)
  minOrderAmount        Decimal?     @db.Decimal(10, 2)
  startAt               DateTime
  endAt                 DateTime
  usageLimit            Int?
  perUserLimit          Int?
  isActive              Boolean      @default(true)
  isDeleted             Boolean      @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  serviceMappings mCouponServiceMappings[]
  bookings        tBookings[]

  @@map("mcoupons")
}

model mCouponServiceMappings {
  iMasterId             Int       @id @default(autoincrement())
  iCouponMasterId       Int
  iServiceMasterId      Int
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  coupon  mCoupons  @relation(fields: [iCouponMasterId], references: [iMasterId], onDelete: Cascade)
  service mServices @relation(fields: [iServiceMasterId], references: [iMasterId], onDelete: Cascade)

  @@unique([iCouponMasterId, iServiceMasterId])
  @@index([iServiceMasterId])
  @@map("mcouponservicemappings")
}

model mHeroServiceMappings {
  iMasterId             Int       @id @default(autoincrement())
  iHeroUserMasterId     Int
  iServiceMasterId      Int
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  hero    mUsers    @relation("HeroServiceMappings", fields: [iHeroUserMasterId], references: [iMasterId], onDelete: Cascade)
  service mServices @relation(fields: [iServiceMasterId], references: [iMasterId], onDelete: Cascade)

  @@unique([iHeroUserMasterId, iServiceMasterId])
  @@index([iServiceMasterId])
  @@map("mheroservicemappings")
}

model mHeroServiceAreas {
  iMasterId             Int       @id @default(autoincrement())
  iHeroUserMasterId     Int
  city                  String?
  state                 String?
  pincode               String?
  latitude              Decimal?  @db.Decimal(10, 7)
  longitude             Decimal?  @db.Decimal(10, 7)
  radiusKm              Decimal?  @db.Decimal(8, 2)
  isActive              Boolean   @default(true)
  isDeleted             Boolean   @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  hero mUsers @relation("HeroServiceAreas", fields: [iHeroUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@index([iHeroUserMasterId])
  @@map("mheroserviceareas")
}

model mHeroLiveLocations {
  iMasterId          Int      @id @default(autoincrement())
  iHeroUserMasterId  Int      @unique
  latitude           Decimal  @db.Decimal(10, 7)
  longitude          Decimal  @db.Decimal(10, 7)
  accuracy           Float?
  heading            Float?
  speed              Float?
  batteryLevel       Float?
  lastUpdatedAt      DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  hero mUsers @relation(fields: [iHeroUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@index([latitude, longitude])
  @@index([lastUpdatedAt])
  @@map("mherolivelocations")
}

model mHubs {
  iMasterId     Int      @id @default(autoincrement())
  sName         String
  addressLine1  String
  city          String
  latitude      Decimal  @db.Decimal(10, 7)
  longitude     Decimal  @db.Decimal(10, 7)
  contactNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  onboardingApplications tHeroOnboardingApplications[]

  @@index([city])
  @@index([isActive])
  @@index([latitude, longitude])
  @@map("mhubs")
}

model tHeroOnboardingApplications {
  iTransId                 Int                    @id @default(autoincrement())
  iHeroUserMasterId        Int                    @unique
  fullName                 String
  mobileNumber             String
  email                    String?
  dateOfBirth              DateTime?
  gender                   String?
  fatherName               String?
  alternateMobileNumber    String?
  addressLine1             String
  addressLine2             String?
  city                     String
  state                    String?
  pincode                  String?
  latitude                 Decimal?               @db.Decimal(10, 7)
  longitude                Decimal?               @db.Decimal(10, 7)
  selectedJobRole          String?
  selectedCity             String?
  workType                 String?
  vehicleType              String?
  earningsType             String?
  onboardingSource         String?
  referralCode             String?
  verificationStatus       HeroVerificationStatus @default(DRAFT)
  nearestHubId             Int?
  submittedAt              DateTime?
  verifiedAt               DateTime?
  verifiedByUserMasterId   Int?
  rejectionReason          String?                @db.Text
  adminRemarks             String?                @db.Text
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  hero        mUsers @relation("HeroOnboardingApplicant", fields: [iHeroUserMasterId], references: [iMasterId], onDelete: Cascade)
  nearestHub  mHubs? @relation(fields: [nearestHubId], references: [iMasterId], onDelete: SetNull)
  verifiedBy  mUsers? @relation("HeroOnboardingVerifiedBy", fields: [verifiedByUserMasterId], references: [iMasterId], onDelete: SetNull)

  @@index([verificationStatus])
  @@index([nearestHubId])
  @@index([verifiedByUserMasterId])
  @@index([city])
  @@index([submittedAt])
  @@map("theroonboardingapplications")
}

model tBookings {
  iTransId               Int           @id @default(autoincrement())
  bookingNo              String        @unique
  iCustomerUserMasterId  Int
  iServiceMasterId       Int?
  requestedServiceName   String?
  quantity               Int           @default(1)
  iAddressMasterId       Int?
  serviceAddressSnapshot Json?
  iSlotMasterId          Int?
  scheduledStartAt       DateTime?
  scheduledEndAt         DateTime?
  iSubscriptionMasterId  Int?
  iCouponMasterId        Int?
  couponCode             String?
  baseAmount             Decimal       @default(0.00) @db.Decimal(10, 2)
  discountAmount         Decimal       @default(0.00) @db.Decimal(10, 2)
  taxAmount              Decimal       @default(0.00) @db.Decimal(10, 2)
  finalAmount            Decimal       @default(0.00) @db.Decimal(10, 2)
  paymentStatus          PaymentStatus @default(PENDING)
  bookingStatus          BookingStatus @default(DRAFT)
  confirmedAt            DateTime?
  holdReason             String?       @db.Text
  cancelledAt            DateTime?
  cancelReason           String?       @db.Text
  remarks                String?       @db.Text
  isActive               Boolean       @default(true)
  isDeleted              Boolean       @default(false)
  deletedAt              DateTime?
  deletedByUserMasterId  Int?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  customer           mUsers?                 @relation("CustomerBookings", fields: [iCustomerUserMasterId], references: [iMasterId])
  service            mServices?              @relation(fields: [iServiceMasterId], references: [iMasterId])
  address            mUserAddresses?         @relation(fields: [iAddressMasterId], references: [iMasterId], onDelete: SetNull)
  slot               mServiceSlots?          @relation(fields: [iSlotMasterId], references: [iMasterId], onDelete: SetNull)
  subscription       mSubscriptions?         @relation(fields: [iSubscriptionMasterId], references: [iMasterId], onDelete: SetNull)
  coupon             mCoupons?               @relation(fields: [iCouponMasterId], references: [iMasterId], onDelete: SetNull)
  assignments        tBookingAssignments[]
  payments           tPayments[]
  images             tBookingImages[]
  ratings            tBookingRatings[]
  statusHistory      tBookingStatusHistory[]
  assignmentAttempts tAssignmentAttempts[]

  @@index([iCustomerUserMasterId])
  @@index([iServiceMasterId])
  @@index([iAddressMasterId])
  @@index([iSlotMasterId])
  @@index([iSubscriptionMasterId])
  @@index([iCouponMasterId])
  @@map("tbookings")
}

model tBookingAssignments {
  iTransId              Int                     @id @default(autoincrement())
  iBookingTransId       Int
  iHeroUserMasterId     Int
  assignedAt            DateTime                @default(now())
  acceptedAt            DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  status                BookingAssignmentStatus @default(ASSIGNED)
  remarks               String?                 @db.Text
  isActive              Boolean                 @default(true)
  isDeleted             Boolean                 @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  booking tBookings @relation(fields: [iBookingTransId], references: [iTransId], onDelete: Cascade)
  hero    mUsers    @relation("HeroAssignments", fields: [iHeroUserMasterId], references: [iMasterId])

  @@index([iBookingTransId])
  @@index([iHeroUserMasterId])
  @@map("tbookingassignments")
}

model tBookingImages {
  iTransId               Int              @id @default(autoincrement())
  iBookingTransId        Int
  imageType              BookingImageType
  imageUrl               String
  uploadedByUserMasterId Int?
  remarks                String?
  isActive               Boolean          @default(true)
  isDeleted              Boolean          @default(false)
  deletedAt              DateTime?
  deletedByUserMasterId  Int?
  createdAt              DateTime         @default(now())

  booking    tBookings @relation(fields: [iBookingTransId], references: [iTransId], onDelete: Cascade)
  uploadedBy mUsers?   @relation("BookingImageUploader", fields: [uploadedByUserMasterId], references: [iMasterId], onDelete: SetNull)

  @@index([iBookingTransId])
  @@index([uploadedByUserMasterId])
  @@map("tbookingimages")
}

model tBookingRatings {
  iTransId              Int               @id @default(autoincrement())
  iBookingTransId       Int
  ratedByUserMasterId   Int
  ratedToUserMasterId   Int
  ratingType            BookingRatingType
  rating                Decimal           @db.Decimal(3, 2)
  review                String?           @db.Text
  isActive              Boolean           @default(true)
  isDeleted             Boolean           @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  booking tBookings @relation(fields: [iBookingTransId], references: [iTransId], onDelete: Cascade)
  ratedBy mUsers    @relation("RatingsGiven", fields: [ratedByUserMasterId], references: [iMasterId])
  ratedTo mUsers    @relation("RatingsReceived", fields: [ratedToUserMasterId], references: [iMasterId])

  @@unique([iBookingTransId, ratingType, ratedByUserMasterId, ratedToUserMasterId])
  @@index([ratedByUserMasterId])
  @@index([ratedToUserMasterId])
  @@map("tbookingratings")
}

model tPayments {
  iTransId              Int             @id @default(autoincrement())
  iBookingTransId       Int
  paidByUserMasterId    Int?
  provider              PaymentProvider @default(PLACEHOLDER)
  providerPaymentId     String?
  providerOrderId       String?
  amount                Decimal         @db.Decimal(10, 2)
  currency              String          @default("INR")
  status                PaymentStatus   @default(PENDING)
  paymentMethod         String?
  rawResponse           Json?
  paidAt                DateTime?
  isActive              Boolean         @default(true)
  isDeleted             Boolean         @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  booking  tBookings          @relation(fields: [iBookingTransId], references: [iTransId], onDelete: Cascade)
  paidBy   mUsers?            @relation("PaymentPayer", fields: [paidByUserMasterId], references: [iMasterId], onDelete: SetNull)
  webhooks tPaymentWebhooks[]

  @@index([iBookingTransId])
  @@index([paidByUserMasterId])
  @@index([providerPaymentId])
  @@map("tpayments")
}

model tPaymentWebhooks {
  iTransId              Int             @id @default(autoincrement())
  iPaymentTransId       Int?
  provider              PaymentProvider @default(PLACEHOLDER)
  eventType             String?
  payload               Json
  receivedAt            DateTime        @default(now())
  processedAt           DateTime?
  processingStatus      String          @default("PENDING")
  errorMessage          String?         @db.Text
  isActive              Boolean         @default(true)
  isDeleted             Boolean         @default(false)
  deletedAt             DateTime?
  deletedByUserMasterId Int?

  payment tPayments? @relation(fields: [iPaymentTransId], references: [iTransId], onDelete: SetNull)

  @@index([iPaymentTransId])
  @@map("tpaymentwebhooks")
}

model AuthSession {
  id               Int       @id @default(autoincrement())
  userId           Int
  refreshTokenHash String    @db.Text
  deviceInfo       String?   @db.Text
  ipAddress        String?   @db.VarChar(64)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user mUsers @relation(fields: [userId], references: [iMasterId], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model mScreens {
  iMasterId      Int      @id @default(autoincrement())
  sCode          String   @unique
  sName          String
  description    String?  @db.Text
  routePath      String?
  parentScreenId Int?
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parentScreen          mScreens?                @relation("ScreenHierarchy", fields: [parentScreenId], references: [iMasterId], onDelete: SetNull)
  childScreens          mScreens[]               @relation("ScreenHierarchy")
  roleScreenPermissions mRoleScreenPermissions[]
  userScreenPermissions mUserScreenPermissions[]

  @@index([parentScreenId])
  @@map("mscreens")
}

model mPermissions {
  iMasterId   Int      @id @default(autoincrement())
  sCode       String   @unique
  sName       String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roleScreenPermissions mRoleScreenPermissions[]
  userScreenPermissions mUserScreenPermissions[]

  @@map("mpermissions")
}

model mRoleScreenPermissions {
  iMasterId    Int      @id @default(autoincrement())
  roleId       Int
  screenId     Int
  permissionId Int
  isAllowed    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role       mRoles       @relation(fields: [roleId], references: [iMasterId], onDelete: Cascade)
  screen     mScreens     @relation(fields: [screenId], references: [iMasterId], onDelete: Cascade)
  permission mPermissions @relation(fields: [permissionId], references: [iMasterId], onDelete: Cascade)

  @@unique([roleId, screenId, permissionId])
  @@index([screenId])
  @@index([permissionId])
  @@map("mrole_screen_permissions")
}

model mUserScreenPermissions {
  iMasterId    Int      @id @default(autoincrement())
  userId       Int
  screenId     Int
  permissionId Int
  isAllowed    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       mUsers       @relation(fields: [userId], references: [iMasterId], onDelete: Cascade)
  screen     mScreens     @relation(fields: [screenId], references: [iMasterId], onDelete: Cascade)
  permission mPermissions @relation(fields: [permissionId], references: [iMasterId], onDelete: Cascade)

  @@unique([userId, screenId, permissionId])
  @@index([screenId])
  @@index([permissionId])
  @@map("muser_screen_permissions")
}

model tAssignmentAttempts {
  iTransId          Int                     @id @default(autoincrement())
  iBookingTransId   Int
  iHeroUserMasterId Int
  attemptNumber     Int
  status            AssignmentAttemptStatus @default(PENDING)
  sentAt            DateTime                @default(now())
  respondedAt       DateTime?
  timeoutAt         DateTime?
  remarks           String?                 @db.Text
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  booking tBookings @relation(fields: [iBookingTransId], references: [iTransId], onDelete: Cascade)
  hero    mUsers    @relation("AssignmentAttemptHero", fields: [iHeroUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@index([iBookingTransId])
  @@index([iHeroUserMasterId])
  @@index([status])
  @@map("tassignmentattempts")
}

model tIdempotencyKeys {
  iTransId              Int      @id @default(autoincrement())
  key                   String
  scope                 String
  requestHash           String
  responseJson          Json?
  createdByUserMasterId Int?
  expiresAt             DateTime
  createdAt             DateTime @default(now())

  createdBy mUsers? @relation("IdempotencyCreatedBy", fields: [createdByUserMasterId], references: [iMasterId], onDelete: SetNull)

  @@unique([key, scope])
  @@index([expiresAt])
  @@index([createdByUserMasterId])
  @@map("tidempotencykeys")
}

model tBookingStatusHistory {
  iTransId              Int            @id @default(autoincrement())
  iBookingTransId       Int
  fromStatus            BookingStatus?
  toStatus              BookingStatus
  changedByUserMasterId Int?
  reason                String?        @db.Text
  metadataJson          Json?
  createdAt             DateTime       @default(now())

  booking   tBookings @relation(fields: [iBookingTransId], references: [iTransId], onDelete: Cascade)
  changedBy mUsers?   @relation("BookingStatusChangedBy", fields: [changedByUserMasterId], references: [iMasterId], onDelete: SetNull)

  @@index([iBookingTransId])
  @@index([changedByUserMasterId])
  @@map("tbookingstatushistory")
}

model mDeviceTokens {
  iMasterId     Int           @id @default(autoincrement())
  iUserMasterId Int
  deviceToken   String
  platform      String
  appType       DeviceAppType
  isActive      Boolean       @default(true)
  lastUsedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user mUsers @relation(fields: [iUserMasterId], references: [iMasterId], onDelete: Cascade)

  @@unique([iUserMasterId, deviceToken])
  @@index([appType])
  @@map("mdevicetokens")
}
